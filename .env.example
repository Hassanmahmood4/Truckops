# Copy to .env at repo root (or rely on npm postinstall once).

# --- API (Express) — required names (not NEXT_PUBLIC_*) ---
PORT=3001
SUPABASE_URL=https://your-project.supabase.co
# Service role secret from Supabase → Project Settings → API (never expose to browser)
SUPABASE_KEY=
CLERK_SECRET_KEY=
QUOTE_RATE_PER_UNIT=2.5
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- Next.js (App Router) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Same SUPABASE_URL + SUPABASE_KEY as above are loaded by Next for /api/* Route Handlers (server-only).
# Optional: point the browser at a remote API instead of same-origin /api
# NEXT_PUBLIC_API_URL=https://your-api.example.com
